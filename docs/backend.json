{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Store user specific information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin", "super_admin"] },
        "authProvider": { "type": "string", "enum": ["password"] },
        "lifetimeSpend": { "type": "number", "default": 0 },
        "currentRank": { "type": "string", "default": "Warrior" },
        "rankId": { "type": "string", "default": "warrior" },
        "rankExpiry": { "type": "string", "format": "date-time" },
        "banned": { "type": "boolean", "default": false },
        "is2FAEnabled": { "type": "boolean", "default": false },
        "twoFactorSecret": { "type": "string", "description": "Hashed secret for TOTP or temporary OTP storage" },
        "twoFactorExpiry": { "type": "string", "format": "date-time" },
        "backupCodes": { "type": "array", "items": { "type": "string" } },
        "lastLoginAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "notifications": {
          "type": "object",
          "properties": {
            "orderUpdates": { "type": "boolean", "default": true },
            "walletUpdates": { "type": "boolean", "default": true },
            "promotional": { "type": "boolean", "default": false },
            "securityAlerts": { "type": "boolean", "default": true }
          }
        }
      },
      "required": ["uid", "email", "fullName", "role"]
    },
    "Banner": {
      "title": "Hero Banner",
      "description": "Slider content for the homepage",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "imageUrl": { "type": "string" },
        "ctaText": { "type": "string" },
        "ctaLink": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "sortOrder": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["imageUrl", "status", "sortOrder"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order for digital assets",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "userId": { "type": "string" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "failed", "cancelled"] },
        "paymentStatus": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "items": { "type": "array" },
        "playerInfo": { "type": "object" }
      },
      "required": ["orderId", "userId", "totalAmount", "status"]
    },
    "Game": {
      "title": "Game",
      "description": "Registry entry for a game or service",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string" },
        "logo": { "type": "string" },
        "banner": { "type": "string" },
        "sortOrder": { "type": "number" }
      },
      "required": ["id", "name", "category"]
    },
    "Product": {
      "title": "Product",
      "description": "SKU package for a specific game",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "tab": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "name", "price", "category"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "User profiles" },
    "/orders/{orderId}": { "schema": "Order", "description": "Customer orders" },
    "/games/{gameId}": { "schema": "Game", "description": "Unified catalog entries" },
    "/products/{productId}": { "schema": "Product", "description": "Managed SKU packages" },
    "/wallets/{userId}": { "schema": "object", "description": "User wallet ledgers" },
    "/transactions/{txId}": { "schema": "object", "description": "Financial logs" },
    "/settings/site": { "schema": "object", "description": "Site global configuration" },
    "/banners/{bannerId}": { "schema": "Banner", "description": "Hero banners for homepage" },
    "/ranks/{rankId}": { "schema": "object", "description": "Membership rank definitions" },
    "/regions/{regionId}": { "schema": "object", "description": "Regional distribution grid" }
  }
}
