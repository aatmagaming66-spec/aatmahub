
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Store user specific information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "photoURL": { "type": "string", "description": "Profile picture URL or Base64 data" },
        "role": { "type": "string", "enum": ["user", "admin", "super_admin"] },
        "lifetimeSpend": { "type": "number", "default": 0 },
        "currentRank": { "type": "string", "default": "Warrior" },
        "rankId": { "type": "string", "default": "warrior" },
        "banned": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "notifications": {
          "type": "object",
          "properties": {
            "orderUpdates": { "type": "boolean", "default": true },
            "walletUpdates": { "type": "boolean", "default": true },
            "promotional": { "type": "boolean", "default": false },
            "securityAlerts": { "type": "boolean", "default": true }
          }
        }
      },
      "required": ["uid", "email", "fullName", "role"]
    },
    "Order": {
      "title": "Order",
      "description": "Stores transaction and purchase details",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "playerInfo": {
          "type": "object",
          "properties": {
            "playerId": { "type": "string" },
            "serverId": { "type": "string" }
          }
        },
        "paymentMethod": { "type": "string", "enum": ["wallet", "razorpay", "phonepe"] },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "cancelled", "failed", "refunded"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Game": {
      "title": "Game",
      "description": "Managed game titles or services in the hub",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "category": { "type": "string", "enum": ["Mobile Games", "OTT Services", "Social Services"] },
        "logo": { "type": "string", "description": "HTTPS URL for the game logo" },
        "banner": { "type": "string", "description": "HTTPS URL for the product page banner" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "sortOrder": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "slug", "category", "status"]
    },
    "Product": {
      "title": "Product",
      "description": "Purchasable digital packages",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "User profiles" },
    "/orders/{orderId}": { "schema": "Order", "description": "Customer orders" },
    "/games/{gameId}": { "schema": "Game", "description": "Managed games and services" },
    "/products/{productId}": { "schema": "Product", "description": "Managed products" },
    "/wallets/{userId}": { "schema": "object", "description": "User wallets" },
    "/transactions/{txId}": { "schema": "object", "description": "Wallet tx" },
    "/settings/site": { "schema": "object", "description": "Global settings" }
  }
}
