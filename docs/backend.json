
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Store user specific information",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Unique identifier for the user"
        },
        "fullName": {
          "type": "string",
          "description": "User's full name"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's email address"
        },
        "phoneNumber": {
          "type": "string",
          "description": "User's phone number"
        },
        "role": {
          "type": "string",
          "enum": [
            "user",
            "admin",
            "super_admin"
          ],
          "description": "User's access role"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the account was created"
        }
      },
      "required": [
        "uid",
        "email",
        "fullName",
        "role"
      ]
    },
    "Order": {
      "title": "Order",
      "description": "Stores transaction and purchase details",
      "type": "object",
      "properties": {
        "orderId": {
          "type": "string",
          "description": "Unique order identifier (e.g., AH-2026-000001)"
        },
        "userId": {
          "type": "string",
          "description": "ID of the user who placed the order"
        },
        "items": {
          "type": "array",
          "description": "List of products purchased"
        },
        "totalAmount": {
          "type": "number",
          "description": "Total cost of the order"
        },
        "playerInfo": {
          "type": "object",
          "properties": {
            "playerId": { "type": "string" },
            "serverId": { "type": "string" }
          }
        },
        "paymentMethod": {
          "type": "string",
          "enum": ["wallet", "razorpay", "phonepe"]
        },
        "status": {
          "type": "string",
          "enum": ["pending", "processing", "completed", "cancelled", "failed"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["orderId", "userId", "items", "totalAmount", "status", "createdAt"]
    },
    "Wallet": {
      "title": "Wallet",
      "description": "Stores user wallet balance",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "balance": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "balance", "updatedAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Wallet transaction records",
      "type": "object",
      "properties": {
        "transactionId": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["deposit", "purchase", "refund"] },
        "status": { "type": "string", "enum": ["pending", "success", "failed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["transactionId", "userId", "amount", "type", "status", "createdAt"]
    },
    "TelegramSettings": {
      "title": "Telegram Settings",
      "description": "Settings for Telegram Bot integration",
      "type": "object",
      "properties": {
        "botToken": { "type": "string" },
        "adminChatId": { "type": "string" },
        "notificationsEnabled": { "type": "boolean" },
        "controlsEnabled": { "type": "boolean" },
        "lastSync": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/wallets/{userId}": {
      "schema": "Wallet",
      "description": "User wallets"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Wallet transactions"
    },
    "/settings/telegram": {
      "schema": "TelegramSettings",
      "description": "Global Telegram configuration"
    }
  }
}
