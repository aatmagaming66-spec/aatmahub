
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Store user specific information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin", "super_admin"] },
        "lifetimeSpend": { "type": "number", "default": 0 },
        "currentRank": { "type": "string", "default": "Warrior" },
        "rankId": { "type": "string", "default": "warrior" },
        "banned": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "fullName", "role"]
    },
    "Order": {
      "title": "Order",
      "description": "Stores transaction and purchase details",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "playerInfo": {
          "type": "object",
          "properties": {
            "playerId": { "type": "string" },
            "serverId": { "type": "string" }
          }
        },
        "paymentMethod": { "type": "string", "enum": ["wallet", "razorpay", "phonepe"] },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "cancelled", "failed", "refunded"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Game": {
      "title": "Game",
      "description": "Managed game titles in the hub",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "icon": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "requirePlayerId": { "type": "boolean" },
        "requireServerId": { "type": "boolean" },
        "requireVerifyId": { "type": "boolean" },
        "sortOrder": { "type": "number" }
      }
    },
    "Product": {
      "title": "Product",
      "description": "Purchasable digital packages",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "discountPrice": { "type": "number" },
        "category": { "type": "string" },
        "region": { "type": "string" },
        "tab": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] }
      }
    },
    "Wallet": {
      "title": "Wallet",
      "properties": {
        "userId": { "type": "string" },
        "balance": { "type": "number" }
      }
    },
    "Transaction": {
      "title": "Transaction",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string" },
        "status": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "User profiles" },
    "/orders/{orderId}": { "schema": "Order", "description": "Customer orders" },
    "/games/{gameId}": { "schema": "Game", "description": "Managed games" },
    "/products/{productId}": { "schema": "Product", "description": "Managed products" },
    "/regions/{regionId}": { "schema": "object", "description": "Managed regions" },
    "/tabs/{tabId}": { "schema": "object", "description": "Managed tabs" },
    "/wallets/{userId}": { "schema": "Wallet", "description": "User wallets" },
    "/transactions/{txId}": { "schema": "Transaction", "description": "Wallet tx" },
    "/settings/site": { "schema": "object", "description": "Global settings" },
    "/settings/payments": { "schema": "object", "description": "Payment config" },
    "/settings/telegram": { "schema": "object", "description": "Bot config" }
  }
}
