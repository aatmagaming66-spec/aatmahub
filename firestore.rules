
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // HELPER FUNCTIONS
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role in ['admin', 'super_admin'];
    }
    
    function isNotBanned() {
      return !getUserData().banned;
    }

    // GLOBAL BANNED CHECK: Block all access if user is banned
    match /{document=**} {
      allow read, write: if false; // Default deny
    }

    // PUBLIC REGISTRY ACCESS
    match /games/{gameId} { allow read: if true; }
    match /products/{productId} { allow read: if true; }
    match /settings/site { allow read: if true; }
    match /banners/{bannerId} { allow read: if true; }
    match /regions/{regionId} { allow read: if true; }
    match /settings/{settingId} { allow read: if true; }

    // USER PROFILE PROTECTION
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if (isOwner(userId) && isNotBanned() && 
                      // Prevent role escalation & field tampering
                      !request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['role', 'banned', 'uid', 'email', 'lifetimeSpend'])) 
                   || isAdmin();
    }
    
    // FINANCIAL LEDGER SECURITY
    match /wallets/{userId} {
      allow read: if isSignedIn() && isOwner(userId);
      allow write: if isAdmin(); // Users NEVER write to their own wallet balance
    }
    
    match /transactions/{txId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isNotBanned() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false; // Transactions are IMMUTABLE
    }
    
    match /orders/{orderId} {
      allow read: if (isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin()))
                  || (resource.data.status == 'completed');
      allow create: if isSignedIn() && isNotBanned() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if false; // Orders are preserved for audit
    }

    // ADMIN OVERRIDE
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
